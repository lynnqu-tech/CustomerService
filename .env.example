APP_NAME=enterprise-rag-customer-service
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_API_V1_PREFIX=/api/v1
API_TOKEN=change-me

OPENAI_API_KEY=change-me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=32
OPENAI_ROUTER_TEMPERATURE=0
OPENAI_RAG_TEMPERATURE=0.2

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=customer_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=1800

REDIS_URL=redis://redis:6379/0
REDIS_SESSION_TTL_SECONDS=1800
REDIS_RESPONSE_CACHE_TTL_SECONDS=300
REDIS_EMBEDDING_CACHE_TTL_SECONDS=86400
REDIS_MAX_CONVERSATION_TURNS=5

MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_COLLECTION=customer_service_docs
MILVUS_DIMENSION=1536
MILVUS_CONSISTENCY_LEVEL=Bounded
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_METRIC_TYPE=COSINE
MILVUS_NLIST=1024
MILVUS_SEARCH_NPROBE=16

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=enterprise-rag-customer-service

#CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

DOCUMENT_CHUNK_SIZE=800
DOCUMENT_CHUNK_OVERLAP=120
DOCUMENT_MAX_FILE_SIZE_MB=10
#DOCUMENT_ALLOWED_EXTENSIONS=.pdf,.txt,.md
DOCUMENT_ALLOWED_EXTENSIONS=[".pdf",".txt",".md"]
DOCUMENT_THREAD_POOL_SIZE=20

QUERY_ROUTER_ORDER_REGEX=(?i)\b(?:order|订单)[\s#:：-]*([A-Z0-9-]{6,32})\b
QUERY_ROUTER_LOGISTICS_REGEX=(?i)\b(?:tracking|物流单号|运单号|快递单号)[\s#:：-]*([A-Z0-9-]{6,32})\b
RAG_TOP_K=4
